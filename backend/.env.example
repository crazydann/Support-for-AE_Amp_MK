# ============================================
# AE Intelligence - 환경 변수 설정
# 이 파일을 복사해서 .env 로 저장하세요
# cp .env.example .env
# ============================================

# [필수] DART OpenAPI 키
# 발급: https://opendart.fss.or.kr/ → 인증키 신청/관리
# 무료, 1-2일 내 발급
DART_API_KEY=your_dart_api_key_here

# [필수] Anthropic Claude API 키
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [선택] SerpAPI 키 (더 정확한 웹 검색)
# 없으면 네이버 검색 자동 사용
# 발급: https://serpapi.com/
SERPAPI_KEY=

# 서버 설정 (기본값 사용 권장)
HOST=0.0.0.0
PORT=8000
